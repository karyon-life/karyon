{
  "name": "docs",
  "type": "module",
  "version": "0.0.1",
  "bin": {
    "research-hub-agents": "./scripts/research-hub-agents.mjs"
  },
  "scripts": {
    "predev": "node scripts/aggregate-book.mjs",
    "mailpit:ensure": "node scripts/ensure-mailpit.mjs",
    "mailpit:up": "node scripts/ensure-mailpit.mjs",
    "mailpit:down": "docker compose -f compose.yml stop mailpit",
    "mailpit:logs": "docker compose -f compose.yml logs -f mailpit",
    "sync:devvars": "node scripts/sync-dev-vars.mjs",
    "d1:migrate:local": "wrangler d1 execute karyon-docs-subscribers --local --file=./migrations/0001_subscribers.sql && wrangler d1 execute karyon-docs-subscribers --local --file=./migrations/0002_agent_runtime.sql && wrangler d1 execute karyon-docs-subscribers --local --file=./migrations/0003_agent_run_trace.sql",
    "agents:test:e2e": "vitest run --maxWorkers=1 src/utils/agents/__tests__/e2e",
    "agents:test:smoke": "node scripts/agents-smoke.mjs",
    "dev": "node scripts/local-dev.mjs",
    "start": "node scripts/local-dev.mjs",
    "prebuild": "node scripts/aggregate-book.mjs",
    "build": "astro build",
    "check": "astro check",
    "cleanup:markdown": "node scripts/cleanup-markdown.mjs --write",
    "cleanup:markdown:check": "node scripts/cleanup-markdown.mjs --check",
    "preview": "astro preview",
    "test:unit": "vitest run --exclude src/utils/agents/__tests__/e2e/**",
    "test:integration": "node scripts/test-cloudflare-local.mjs",
    "test": "npm run test:unit && npm run test:integration",
    "agents": "node scripts/research-hub-agents.mjs",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/starlight": "^0.37.6",
    "@tailwindcss/vite": "^4.1.4",
    "astro": "^5.6.1",
    "katex": "^0.16.22",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-mdx": "^3.1.1",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "sharp": "^0.34.2",
    "tailwindcss": "^4.1.4",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/cloudflare": "^12.6.13",
    "@types/nodemailer": "^7.0.11",
    "nodemailer": "^8.0.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2",
    "wrangler": "^4.80.0"
  }
}
