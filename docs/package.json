{
  "name": "karyon-docs",
  "private": true,
  "type": "module",
  "version": "0.0.1",
  "workspaces": [
    "packages/core",
    "packages/sdk"
  ],
  "scripts": {
    "starlight:patch": "treeseed starlight:patch",
    "postinstall": "npm run starlight:patch",
    "dev": "treeseed dev",
    "dev:watch": "treeseed dev --watch",
    "start": "npm run dev",
    "build": "treeseed build",
    "check": "treeseed check",
    "deploy": "treeseed deploy",
    "destroy": "treeseed destroy",
    "preview": "treeseed preview",
    "astro": "treeseed astro",
    "mailpit:up": "treeseed mailpit:up",
    "mailpit:down": "treeseed mailpit:down",
    "mailpit:logs": "treeseed mailpit:logs",
    "sync:devvars": "treeseed sync:devvars",
    "d1:migrate:local": "treeseed d1:migrate:local",
    "cleanup:markdown": "treeseed cleanup:markdown",
    "cleanup:markdown:check": "treeseed cleanup:markdown:check",
    "test:unit": "node ./scripts/workspace-test-unit.mjs",
    "test:integration": "treeseed test:integration",
    "test:e2e": "treeseed test:e2e",
    "test:release": "node ./scripts/release-verify.mjs",
    "test:release:full": "node ./scripts/release-verify.mjs --full-smoke",
