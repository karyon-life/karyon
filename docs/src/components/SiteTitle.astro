---
import Default from '@astrojs/starlight/components/SiteTitle.astro';
---

<div class="site-header-custom sl-flex">
  <Default {...Astro.props} />
  <a href="/karyon-architecture-book.md" download="karyon-architecture-book.md" class="download-button">
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-download">
      <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
      <polyline points="7 10 12 15 17 10"/>
      <line x1="12" x2="12" y1="15" y2="3"/>
    </svg>
    Download Book (.md)
  </a>
</div>

<style>
  .site-header-custom {
    align-items: center;
    gap: 1.5rem;
  }
  .download-button {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: var(--sl-text-sm);
    padding: 0.3rem 0.8rem;
    background-color: var(--sl-color-bg-inline-code);
    color: var(--sl-color-text-accent);
    text-decoration: none;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 9999px;
    font-weight: 500;
    transition: all 0.2s ease-in-out;
  }
  .download-button:hover {
    background-color: var(--sl-color-gray-6);
    border-color: var(--sl-color-text-accent);
  }
</style>
