{
  "name": "@treeseed/cli",
  "version": "0.0.1",
  "description": "Operator-facing Treeseed CLI package.",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/treeseed-ai/cli.git",
    "directory": "."
  },
  "homepage": "https://treeseed.ai",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "README.md",
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "setup": "npm install",
    "setup:ci": "npm ci",
    "test": "node --test ./scripts/*.test.mjs",
    "build:dist": "node ./scripts/build-dist.mjs",
    "prepare": "npm run build:dist",
    "prepack": "npm run build:dist",
    "release:setup": "npm run setup:ci",
    "release:check-tag": "node ./scripts/assert-release-tag-version.mjs",
    "release:verify": "npm run build:dist",
    "release:publish": "node ./scripts/publish-package.mjs"
  },
  "dependencies": {
    "@treeseed/agent": "^0.0.1",
    "@treeseed/core": "^0.0.1",
    "@treeseed/sdk": "^0.0.1",
    "esbuild": "^0.25.10",
    "typescript": "^5.9.3",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/node": "^24.6.0"
  },
  "bin": {
    "treeseed": "./dist/scripts/treeseed.js"
  }
}
